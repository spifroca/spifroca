# ─── Datenbank ────────────────────────────────────────────────────────────────
POSTGRES_USER=spifroca
POSTGRES_PASSWORD=spifroca_secret_2024
POSTGRES_DB=spifroca
DATABASE_URL="postgresql://spifroca:spifroca_secret_2024@localhost:5432/spifroca"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_in_production_min32chars!!
NEXTAUTH_URL=http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=spifroca
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

